# FormSubmit public endpoint.
# First activation can use https://formsubmit.co/you@example.com
# After confirming the email, replace it with the invisible endpoint/token.
VITE_FORMSUBMIT_ACTION=https://formsubmit.co/your-random-string

# Public base URL used by FormSubmit to redirect back to /contact?sent=1
VITE_SITE_URL=https://yourdomain.com
